@model EMPS.Web.Models.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Employee Payroll System</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Custom site.css styling -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="auth-container">
        <div class="auth-card">
            <div class="text-center mb-4">
                <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px; font-size: 1.75rem;">
                    <i class="fa-solid fa-wallet"></i>
                </div>
                <h3 class="fw-bold text-main m-0">Welcome Back</h3>
                <p class="text-muted mt-1" style="font-size: 0.9rem;">Sign in to your EMPS account</p>
            </div>

            <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size: 0.85rem;"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label form-label-custom">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-muted" style="border-radius: 8px 0 0 8px; border-color: var(--border-color);"><i class="fa-solid fa-envelope"></i></span>
                        <input asp-for="Email" class="form-control form-control-custom border-start-0" style="border-radius: 0 8px 8px 0;" placeholder="name@company.com" autocomplete="username" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger" style="font-size: 0.8rem;"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label form-label-custom">Password</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-muted" style="border-radius: 8px 0 0 8px; border-color: var(--border-color);"><i class="fa-solid fa-lock"></i></span>
                        <input asp-for="Password" class="form-control form-control-custom border-start-0" style="border-radius: 0 8px 8px 0;" placeholder="••••••••" autocomplete="current-password" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger" style="font-size: 0.8rem;"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4" style="font-size: 0.9rem;">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label text-muted">Remember me</label>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2.5 fw-semibold" style="border-radius: 8px;">
                    <i class="fa-solid fa-right-to-bracket me-2"></i>Sign In
                </button>
            </form>

            <div class="text-center mt-4 border-top pt-3 text-muted" style="font-size: 0.8rem;">
                <p class="m-0">Demo credentials: admin@emps.com / Admin@123</p>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
