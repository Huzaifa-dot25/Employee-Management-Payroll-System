@model EMPS.Web.Models.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="row justify-content-center">
    <div class="col-12 col-md-7 col-lg-5">

        <div class="form-page-header mb-4">
            <div class="form-page-icon" style="background:linear-gradient(135deg,#4f46e5,#818cf8);">
                <i class="fa-solid fa-lock"></i>
            </div>
            <div>
                <h4 class="form-page-title">Change Password</h4>
                <p class="form-page-sub">Update your account password</p>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success d-flex align-items-center gap-2 mb-4">
                <i class="fa-solid fa-circle-check"></i>
                <span>@TempData["SuccessMessage"]</span>
            </div>
        }

        <div class="form-card">
            <form asp-action="ChangePassword" method="post" autocomplete="off">
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="alert alert-danger mb-4" style="font-size:.825rem;">
                        <i class="fa-solid fa-circle-xmark me-2"></i>
                        <div asp-validation-summary="ModelOnly"></div>
                    </div>
                }

                <div class="form-field-group mb-4">
                    <div class="form-section-label mb-3">
                        <i class="fa-solid fa-key"></i> Current Password
                    </div>

                    <div class="mb-3">
                        <label asp-for="CurrentPassword" class="form-label fw-semibold" style="font-size:.825rem;"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0">
                                <i class="fa-solid fa-lock text-muted" style="font-size:.8rem;"></i>
                            </span>
                            <input asp-for="CurrentPassword" type="password"
                                   class="form-control border-start-0 ps-0"
                                   placeholder="Enter your current password"
                                   id="currentPwd" autocomplete="current-password" />
                            <button class="btn btn-outline-secondary border-start-0" type="button"
                                    onclick="togglePwd('currentPwd', 'iconCurrent')" tabindex="-1">
                                <i id="iconCurrent" class="fa-regular fa-eye" style="font-size:.8rem;"></i>
                            </button>
                        </div>
                        <span asp-validation-for="CurrentPassword" class="field-error"></span>
                    </div>
                </div>

                <div class="form-field-group mb-4">
                    <div class="form-section-label mb-3">
                        <i class="fa-solid fa-shield-halved"></i> New Password
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label fw-semibold" style="font-size:.825rem;"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0">
                                <i class="fa-solid fa-lock-open text-muted" style="font-size:.8rem;"></i>
                            </span>
                            <input asp-for="NewPassword" type="password"
                                   class="form-control border-start-0 ps-0"
                                   placeholder="At least 6 characters"
                                   id="newPwd" autocomplete="new-password"
                                   oninput="checkStrength(this.value)" />
                            <button class="btn btn-outline-secondary border-start-0" type="button"
                                    onclick="togglePwd('newPwd', 'iconNew')" tabindex="-1">
                                <i id="iconNew" class="fa-regular fa-eye" style="font-size:.8rem;"></i>
                            </button>
                        </div>
                        <span asp-validation-for="NewPassword" class="field-error"></span>

                        @* Password strength bar *@
                        <div class="mt-2" id="strengthWrap" style="display:none;">
                            <div style="height:4px;background:#e5e7eb;border-radius:2px;overflow:hidden;">
                                <div id="strengthBar" style="height:100%;border-radius:2px;transition:width .3s,background .3s;width:0%;"></div>
                            </div>
                            <div id="strengthLabel" class="mt-1" style="font-size:.72rem;font-weight:600;"></div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold" style="font-size:.825rem;"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0">
                                <i class="fa-solid fa-check-double text-muted" style="font-size:.8rem;"></i>
                            </span>
                            <input asp-for="ConfirmPassword" type="password"
                                   class="form-control border-start-0 ps-0"
                                   placeholder="Repeat new password"
                                   id="confirmPwd" autocomplete="new-password" />
                            <button class="btn btn-outline-secondary border-start-0" type="button"
                                    onclick="togglePwd('confirmPwd', 'iconConfirm')" tabindex="-1">
                                <i id="iconConfirm" class="fa-regular fa-eye" style="font-size:.8rem;"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="field-error"></span>
                    </div>
                </div>

                @* Password rules hint *@
                <div class="p-3 mb-4 rounded" style="background:#f8f9ff;border:1px solid #e0e4ff;font-size:.78rem;color:#6b7280;">
                    <div class="fw-bold mb-1" style="color:#374151;">Password requirements</div>
                    <ul class="mb-0 ps-3">
                        <li>Minimum 6 characters</li>
                        <li>Mix of letters and numbers recommended</li>
                        <li>Do not reuse your last password</li>
                    </ul>
                </div>

                <div class="form-actions">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary px-5">
                        <i class="fa-solid fa-lock me-2"></i>Update Password
                    </button>
                </div>
            </form>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePwd(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon  = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }

        function checkStrength(val) {
            const wrap  = document.getElementById('strengthWrap');
            const bar   = document.getElementById('strengthBar');
            const label = document.getElementById('strengthLabel');

            if (!val) { wrap.style.display = 'none'; return; }
            wrap.style.display = 'block';

            let score = 0;
            if (val.length >= 6)  score++;
            if (val.length >= 10) score++;
            if (/[A-Z]/.test(val))  score++;
            if (/[0-9]/.test(val))  score++;
            if (/[^A-Za-z0-9]/.test(val)) score++;

            const levels = [
                { pct: '20%',  bg: '#ef4444', text: 'Very weak',  cls: 'text-danger'  },
                { pct: '40%',  bg: '#f97316', text: 'Weak',       cls: 'text-warning' },
                { pct: '60%',  bg: '#f59e0b', text: 'Fair',       cls: 'text-warning' },
                { pct: '80%',  bg: '#10b981', text: 'Strong',     cls: 'text-success' },
                { pct: '100%', bg: '#059669', text: 'Very strong', cls: 'text-success' },
            ];
            const lvl = levels[Math.min(score - 1, 4)] || levels[0];
            bar.style.width      = lvl.pct;
            bar.style.background = lvl.bg;
            label.textContent    = lvl.text;
            label.className      = lvl.cls;
        }
    </script>
}
