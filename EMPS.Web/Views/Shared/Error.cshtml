@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="d-flex flex-column align-items-center justify-content-center" style="min-height:60vh;text-align:center;">
    <div style="font-size:4rem;color:#e5e7eb;margin-bottom:16px;">
        <i class="fa-solid fa-triangle-exclamation" style="color:#ef4444;"></i>
    </div>
    <h2 style="font-size:1.4rem;font-weight:800;color:#111827;margin-bottom:8px;">Something went wrong</h2>
    <p style="color:#6b7280;font-size:.875rem;max-width:420px;margin-bottom:24px;">
        An unexpected error occurred while processing your request. Please try again or contact your administrator.
    </p>

    @if (Model.ShowRequestId)
    {
        <div class="mb-4 p-3" style="background:#f1f3ff;border:1px solid #dde1ff;border-radius:8px;font-size:.8rem;">
            <span style="color:#6b7280;">Request ID: </span>
            <code>@Model.RequestId</code>
        </div>
    }

    <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-5">
        <i class="fa-solid fa-house me-2"></i>Back to Dashboard
    </a>
</div>
