@using Microsoft.AspNetCore.Identity
@using EMPS.Core.Entities
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — EMPS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300..900;1,14..32,300..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.4.1/css/responsive.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

@if (SignInManager.IsSignedIn(User))
{
    <!-- Mobile overlay -->
    <div id="sidebar-overlay" class="sidebar-overlay"></div>
}

<div class="app-container">

    @if (SignInManager.IsSignedIn(User))
    {
        var ctrl = ViewContext.RouteData.Values["Controller"]?.ToString();

        <!-- ── Sidebar ─────────────────────────────────────────── -->
        <aside class="sidebar" id="sidebar">
            <!-- Close button (mobile only) -->
            <button id="btn-sidebar-close" class="sidebar-close-btn" aria-label="Close menu">
                <i class="fa-solid fa-xmark"></i>
            </button>

            <div class="sidebar-brand">
                <div class="brand-icon"><i class="fa-solid fa-wallet"></i></div>
                <span>EMPS Payroll</span>
            </div>

            <ul class="sidebar-menu">

                @* ── Main ── *@
                <li class="sidebar-section-label">Main</li>

                <li class="sidebar-item @(ctrl == "Home" ? "active" : "")">
                    <a class="sidebar-link" asp-controller="Home" asp-action="Index">
                        <i class="fa-solid fa-gauge-high"></i>
                        <span>Dashboard</span>
                    </a>
                </li>

                @* ── Organisation (Admin/HR only) ── *@
                @if (User.IsInRole("Admin") || User.IsInRole("HR"))
                {
                    <li class="sidebar-section-label">Organisation</li>

                    <li class="sidebar-item @(ctrl == "Department" ? "active" : "")">
                        <a class="sidebar-link" asp-controller="Department" asp-action="Index">
                            <i class="fa-solid fa-sitemap"></i>
                            <span>Departments</span>
                        </a>
                    </li>
                    <li class="sidebar-item @(ctrl == "Designation" ? "active" : "")">
                        <a class="sidebar-link" asp-controller="Designation" asp-action="Index">
                            <i class="fa-solid fa-id-badge"></i>
                            <span>Designations</span>
                        </a>
                    </li>
                    <li class="sidebar-item @(ctrl == "Employee" ? "active" : "")">
                        <a class="sidebar-link" asp-controller="Employee" asp-action="Index">
                            <i class="fa-solid fa-users"></i>
                            <span>Employees</span>
                        </a>
                    </li>
                }

                @* ── Workforce ── *@
                <li class="sidebar-section-label">Workforce</li>

                <li class="sidebar-item @(ctrl == "Attendance" ? "active" : "")">
                    <a class="sidebar-link" asp-controller="Attendance" asp-action="Index">
                        <i class="fa-solid fa-calendar-check"></i>
                        <span>Attendance</span>
                    </a>
                </li>
                <li class="sidebar-item @(ctrl == "Leave" ? "active" : "")">
                    <a class="sidebar-link" asp-controller="Leave" asp-action="Index">
                        <i class="fa-solid fa-plane-departure"></i>
                        <span>Leave Requests</span>
                    </a>
                </li>

                @* ── Payroll ── *@
                @if (User.IsInRole("Admin") || User.IsInRole("HR"))
                {
                    <li class="sidebar-section-label">Finance</li>

                    <li class="sidebar-item @(ctrl == "Payroll" ? "active" : "")">
                        <a class="sidebar-link" asp-controller="Payroll" asp-action="Index">
                            <i class="fa-solid fa-receipt"></i>
                            <span>Payroll</span>
                        </a>
                    </li>
                    <li class="sidebar-item @(ctrl == "Report" ? "active" : "")">
                        <a class="sidebar-link" asp-controller="Report" asp-action="Index">
                            <i class="fa-solid fa-chart-line"></i>
                            <span>Reports</span>
                        </a>
                    </li>
                }
                else
                {
                    <li class="sidebar-section-label">Finance</li>
                    <li class="sidebar-item @(ctrl == "Payroll" ? "active" : "")">
                        <a class="sidebar-link" asp-controller="Payroll" asp-action="MyPayslips">
                            <i class="fa-solid fa-file-invoice-dollar"></i>
                            <span>My Payslips</span>
                        </a>
                    </li>
                }

                @* ── System (Admin only) ── *@
                @if (User.IsInRole("Admin"))
                {
                    <li class="sidebar-section-label">System</li>
                    <li class="sidebar-item @(ctrl == "UserRole" ? "active" : "")">
                        <a class="sidebar-link" asp-controller="UserRole" asp-action="Index">
                            <i class="fa-solid fa-shield-halved"></i>
                            <span>Role Management</span>
                        </a>
                    </li>
                }

            </ul>

            <!-- Sidebar footer -->
            <div class="sidebar-footer">
                <div style="font-size:.65rem;color:rgba(255,255,255,.25);text-align:center;letter-spacing:.5px;">
                    EMPS &copy; @DateTime.Now.Year
                </div>
            </div>
        </aside>
    }

    <!-- ── Main Content ─────────────────────────────────────── -->
    <div class="main-content">

        <!-- Top Navbar -->
        <header class="top-navbar">
            <div class="d-flex align-items-center gap-3">
                @if (SignInManager.IsSignedIn(User))
                {
                    <!-- Hamburger (mobile) -->
                    <button id="btn-sidebar-open" class="hamburger-btn d-lg-none" aria-label="Open menu">
                        <i class="fa-solid fa-bars"></i>
                    </button>
                    <h5 class="page-title mb-0">@ViewData["Title"]</h5>
                }
                else
                {
                    <h5 class="page-title mb-0">
                        <i class="fa-solid fa-wallet me-2 text-primary"></i>EMPS Payroll
                    </h5>
                }
            </div>

            <div class="d-flex align-items-center gap-2">
                @if (SignInManager.IsSignedIn(User))
                {
                    var currentUser = await UserManager.GetUserAsync(User);

                    <!-- Profile dropdown -->
                    <div class="dropdown">
                        <button class="user-pill border-0 dropdown-toggle" type="button"
                                id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            <div class="user-avatar">
                                @(currentUser?.FullName?.Length > 0 ? currentUser.FullName[0].ToString().ToUpper() : "U")
                            </div>
                            <div class="text-start d-none d-sm-block">
                                <div class="user-info-name">@(currentUser?.FullName ?? User.Identity?.Name)</div>
                                <div class="user-info-role">
                                    @(User.IsInRole("Admin") ? "Administrator" : User.IsInRole("HR") ? "HR Manager" : "Employee")
                                </div>
                            </div>
                            <i class="fa-solid fa-chevron-down ms-1 text-muted" style="font-size:.62rem;"></i>
                        </button>

                        <ul class="dropdown-menu dropdown-menu-end mt-2 shadow" aria-labelledby="userDropdown">
                            <li>
                                <div class="px-3 py-2 border-bottom mb-1">
                                    <div style="font-size:.8rem;font-weight:700;color:#111827;">@(currentUser?.FullName ?? "User")</div>
                                    <div style="font-size:.72rem;color:#6b7280;">@(currentUser?.Email ?? "")</div>
                                </div>
                            </li>
                            <li>
                                <a asp-controller="Account" asp-action="ChangePassword"
                                   class="dropdown-item d-flex align-items-center gap-2">
                                    <i class="fa-solid fa-lock" style="color:#4f46e5;width:14px;"></i>
                                    <span>Change Password</span>
                                </a>
                            </li>
                            <li><hr class="dropdown-divider my-1"></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    <button type="submit" class="dropdown-item text-danger d-flex align-items-center gap-2">
                                        <i class="fa-solid fa-right-from-bracket" style="width:14px;"></i>
                                        <span>Sign out</span>
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a class="btn btn-primary btn-sm" asp-controller="Account" asp-action="Login">
                        <i class="fa-solid fa-right-to-bracket me-2"></i>Login
                    </a>
                }
            </div>
        </header>

        <!-- Content Body -->
        <main class="content-wrapper">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mb-4" role="alert"
                     style="border-radius:10px;border-left:4px solid #10b981;">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fa-solid fa-circle-check text-success"></i>
                        <span>@Html.Raw(TempData["SuccessMessage"])</span>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert"
                     style="border-radius:10px;border-left:4px solid #ef4444;">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fa-solid fa-circle-xmark text-danger"></i>
                        <span>@Html.Raw(TempData["ErrorMessage"])</span>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @RenderBody()
        </main>

    </div><!-- /main-content -->
</div><!-- /app-container -->

<!-- Scripts -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.datatables.net/responsive/2.4.1/js/dataTables.responsive.min.js"></script>
<script src="https://cdn.datatables.net/responsive/2.4.1/js/responsive.bootstrap5.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
