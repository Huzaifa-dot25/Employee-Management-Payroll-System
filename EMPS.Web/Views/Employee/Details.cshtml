@model EMPS.Web.Models.EmployeeViewModel
@{
    ViewData["Title"] = "Employee Profile Details";
}

<div class="row g-4">
    <!-- Left Profile Side Card -->
    <div class="col-12 col-lg-4">
        <div class="card-flat text-center">
            <div class="card-flat-body">
                <div class="d-inline-block bg-primary-subtle border rounded-circle mb-3 d-flex align-items-center justify-content-center mx-auto" style="width: 130px; height: 130px; overflow: hidden;">
                    @if (!string.IsNullOrEmpty(Model.ProfilePhotoPath))
                    {
                        <img src="@Model.ProfilePhotoPath" alt="Profile Photo" style="width: 130px; height: 130px; object-fit: cover;" />
                    }
                    else
                    {
                        <span class="text-primary fw-bold" style="font-size: 3.5rem;">@Model.FirstName.Substring(0, 1).ToUpper()</span>
                    }
                </div>
                <h4 class="fw-bold text-main mb-1">@Model.FullName</h4>
                <p class="text-muted mb-2">@Model.DesignationName</p>
                <div class="mb-3">
                    @if (Model.EmploymentStatus == "Active")
                    {
                        <span class="badge bg-success-subtle text-success badge-custom fs-7">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-danger-subtle text-danger badge-custom fs-7">@Model.EmploymentStatus</span>
                    }
                </div>
                <hr />
                <div class="text-start mt-4">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <i class="fa-solid fa-id-card text-muted" style="width: 20px;"></i>
                        <div>
                            <div class="text-muted" style="font-size: 0.75rem;">Employee Code</div>
                            <div class="fw-semibold text-main"><code>@Model.EmployeeCode</code></div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <i class="fa-solid fa-envelope text-muted" style="width: 20px;"></i>
                        <div>
                            <div class="text-muted" style="font-size: 0.75rem;">Email Address</div>
                            <div class="fw-semibold text-main">@Model.Email</div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <i class="fa-solid fa-phone text-muted" style="width: 20px;"></i>
                        <div>
                            <div class="text-muted" style="font-size: 0.75rem;">Phone Number</div>
                            <div class="fw-semibold text-main">@Model.PhoneNumber</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Profile Info Side Panel -->
    <div class="col-12 col-lg-8">
        <div class="d-flex flex-column gap-4">
            <!-- Full Profile Data Overview -->
            <div class="card-flat">
                <div class="card-flat-header">
                    <h5 class="m-0 fw-bold"><i class="fa-solid fa-address-card text-primary me-2"></i>Profile Information</h5>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm"><i class="fa-solid fa-pen me-1"></i>Edit Profile</a>
                </div>
                <div class="card-flat-body">
                    <div class="row g-4">
                        <!-- Left Info Column -->
                        <div class="col-12 col-sm-6">
                            <h6 class="text-muted fw-semibold text-uppercase mb-3" style="font-size: 0.75rem;">Employment Profile</h6>
                            <div class="d-flex flex-column gap-3">
                                <div>
                                    <div class="text-muted" style="font-size: 0.75rem;">Department</div>
                                    <div class="fw-semibold text-main">@Model.DepartmentName</div>
                                </div>
                                <div>
                                    <div class="text-muted" style="font-size: 0.75rem;">Designation</div>
                                    <div class="fw-semibold text-main">@Model.DesignationName</div>
                                </div>
                                <div>
                                    <div class="text-muted" style="font-size: 0.75rem;">Joining Date</div>
                                    <div class="fw-semibold text-main">@Model.JoiningDate.ToString("MMMM dd, yyyy")</div>
                                </div>
                                <div>
                                    <div class="text-muted" style="font-size: 0.75rem;">Basic Salary</div>
                                    <div class="fw-semibold text-main">$@Model.BasicSalary.ToString("N2")</div>
                                </div>
                            </div>
                        </div>

                        <!-- Right Info Column -->
                        <div class="col-12 col-sm-6">
                            <h6 class="text-muted fw-semibold text-uppercase mb-3" style="font-size: 0.75rem;">Personal Details</h6>
                            <div class="d-flex flex-column gap-3">
                                <div>
                                    <div class="text-muted" style="font-size: 0.75rem;">Gender</div>
                                    <div class="fw-semibold text-main">@Model.Gender</div>
                                </div>
                                <div>
                                    <div class="text-muted" style="font-size: 0.75rem;">Date of Birth</div>
                                    <div class="fw-semibold text-main">@Model.DateOfBirth.ToString("MMMM dd, yyyy")</div>
                                </div>
                                <div>
                                    <div class="text-muted" style="font-size: 0.75rem;">Bank / Bank Branch</div>
                                    <div class="fw-semibold text-main">@Model.BankName</div>
                                </div>
                                <div>
                                    <div class="text-muted" style="font-size: 0.75rem;">Bank Account Number</div>
                                    <div class="fw-semibold text-main">@Model.BankAccountNumber</div>
                                </div>
                                <div>
                                    <div class="text-muted" style="font-size: 0.75rem;">Tax ID / PAN</div>
                                    <div class="fw-semibold text-main">@Model.TaxIdentificationNumber</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
