@model EMPS.Web.Models.EmployeeViewModel
@{
    ViewData["Title"] = "Employee Profile";
}

<div class="row g-4">

    <!-- Profile Card -->
    <div class="col-12 col-lg-4">
        <div class="profile-card">
            <div class="profile-card-banner"></div>
            <div class="profile-card-body">
                <div class="profile-avatar-wrap">
                    @if (!string.IsNullOrEmpty(Model.ProfilePhotoPath))
                    {
                        <img src="@Model.ProfilePhotoPath" alt="Profile" class="profile-avatar-img" />
                    }
                    else
                    {
                        <div class="profile-avatar-initials">
                            @Model.FirstName.Substring(0, 1).ToUpper()
                        </div>
                    }
                </div>
                <h4 class="profile-name">@Model.FullName</h4>
                <p class="profile-designation">@Model.DesignationName</p>
                <div class="mb-3">
                    @if (Model.EmploymentStatus == "Active")
                    {
                        <span class="badge bg-success-subtle text-success badge-custom px-3">
                            <i class="fa-solid fa-circle-check me-1" style="font-size:0.65rem;"></i>Active
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger-subtle text-danger badge-custom px-3">@Model.EmploymentStatus</span>
                    }
                </div>

                <div class="profile-meta-list">
                    <div class="profile-meta-item">
                        <div class="profile-meta-icon"><i class="fa-solid fa-id-badge"></i></div>
                        <div>
                            <div class="profile-meta-label">Employee Code</div>
                            <code class="profile-meta-value">@Model.EmployeeCode</code>
                        </div>
                    </div>
                    <div class="profile-meta-item">
                        <div class="profile-meta-icon"><i class="fa-solid fa-envelope"></i></div>
                        <div>
                            <div class="profile-meta-label">Email</div>
                            <div class="profile-meta-value">@Model.Email</div>
                        </div>
                    </div>
                    <div class="profile-meta-item">
                        <div class="profile-meta-icon"><i class="fa-solid fa-phone"></i></div>
                        <div>
                            <div class="profile-meta-label">Phone</div>
                            <div class="profile-meta-value">@Model.PhoneNumber</div>
                        </div>
                    </div>
                    <div class="profile-meta-item">
                        <div class="profile-meta-icon"><i class="fa-solid fa-sitemap"></i></div>
                        <div>
                            <div class="profile-meta-label">Department</div>
                            <div class="profile-meta-value">@Model.DepartmentName</div>
                        </div>
                    </div>
                </div>

                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary w-100 mt-2">
                    <i class="fa-solid fa-pen me-2"></i>Edit Profile
                </a>
            </div>
        </div>
    </div>

    <!-- Info Panels -->
    <div class="col-12 col-lg-8">
        <div class="d-flex flex-column gap-4">

            <!-- Employment -->
            <div class="info-panel">
                <div class="info-panel-header">
                    <i class="fa-solid fa-briefcase text-primary"></i>
                    <span>Employment Details</span>
                </div>
                <div class="info-panel-body">
                    <div class="row g-0">
                        <div class="col-12 col-sm-6">
                            <div class="info-field">
                                <div class="info-field-label">Designation</div>
                                <div class="info-field-value">@Model.DesignationName</div>
                            </div>
                        </div>
                        <div class="col-12 col-sm-6">
                            <div class="info-field">
                                <div class="info-field-label">Department</div>
                                <div class="info-field-value">@Model.DepartmentName</div>
                            </div>
                        </div>
                        <div class="col-12 col-sm-6">
                            <div class="info-field">
                                <div class="info-field-label">Joining Date</div>
                                <div class="info-field-value">@Model.JoiningDate.ToString("MMMM dd, yyyy")</div>
                            </div>
                        </div>
                        <div class="col-12 col-sm-6">
                            <div class="info-field">
                                <div class="info-field-label">Basic Salary</div>
                                <div class="info-field-value fw-700 text-success">$@Model.BasicSalary.ToString("N2")</div>
                            </div>
                        </div>
                        <div class="col-12 col-sm-6">
                            <div class="info-field border-bottom-0">
                                <div class="info-field-label">Employment Status</div>
                                <div class="info-field-value">@Model.EmploymentStatus</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Personal -->
            <div class="info-panel">
                <div class="info-panel-header">
                    <i class="fa-solid fa-user text-primary"></i>
                    <span>Personal Information</span>
                </div>
                <div class="info-panel-body">
                    <div class="row g-0">
                        <div class="col-12 col-sm-6">
                            <div class="info-field">
                                <div class="info-field-label">Full Name</div>
                                <div class="info-field-value">@Model.FullName</div>
                            </div>
                        </div>
                        <div class="col-12 col-sm-6">
                            <div class="info-field">
                                <div class="info-field-label">Gender</div>
                                <div class="info-field-value">@Model.Gender</div>
                            </div>
                        </div>
                        <div class="col-12 col-sm-6">
                            <div class="info-field">
                                <div class="info-field-label">Date of Birth</div>
                                <div class="info-field-value">@Model.DateOfBirth.ToString("MMMM dd, yyyy")</div>
                            </div>
                        </div>
                        <div class="col-12 col-sm-6">
                            <div class="info-field border-bottom-0">
                                <div class="info-field-label">Email Address</div>
                                <div class="info-field-value">@Model.Email</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bank & Tax -->
            <div class="info-panel">
                <div class="info-panel-header">
                    <i class="fa-solid fa-building-columns text-primary"></i>
                    <span>Bank & Tax Details</span>
                </div>
                <div class="info-panel-body">
                    <div class="row g-0">
                        <div class="col-12 col-sm-6">
                            <div class="info-field">
                                <div class="info-field-label">Bank Name</div>
                                <div class="info-field-value">@Model.BankName</div>
                            </div>
                        </div>
                        <div class="col-12 col-sm-6">
                            <div class="info-field">
                                <div class="info-field-label">Account Number</div>
                                <div class="info-field-value">@Model.BankAccountNumber</div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="info-field border-bottom-0">
                                <div class="info-field-label">Tax ID / PAN</div>
                                <div class="info-field-value">@Model.TaxIdentificationNumber</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
