@model EMPS.Web.Models.DepartmentViewModel
@{
    ViewData["Title"] = "Edit Department";
}

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card-flat">
            <div class="card-flat-header">
                <h5 class="m-0 fw-bold"><i class="fa-solid fa-pen text-primary me-2"></i>Edit Department</h5>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="fa-solid fa-arrow-left me-1"></i>Back</a>
            </div>
            <div class="card-flat-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Code" class="form-label form-label-custom">Department Code</label>
                        <input asp-for="Code" class="form-control form-control-custom" />
                        <span asp-validation-for="Code" class="text-danger" style="font-size: 0.8rem;"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label form-label-custom">Department Name</label>
                        <input asp-for="Name" class="form-control form-control-custom" />
                        <span asp-validation-for="Name" class="text-danger" style="font-size: 0.8rem;"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label form-label-custom">Description</label>
                        <textarea asp-for="Description" class="form-control form-control-custom" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger" style="font-size: 0.8rem;"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                        <i class="fa-solid fa-floppy-disk me-2"></i>Update Department
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
