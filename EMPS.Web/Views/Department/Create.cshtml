@model EMPS.Web.Models.DepartmentViewModel
@{
    ViewData["Title"] = "Add Department";
}

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">

        <div class="form-page-header mb-4">
            <div class="form-page-icon"><i class="fa-solid fa-sitemap"></i></div>
            <div>
                <h4 class="form-page-title">Add Department</h4>
                <p class="form-page-sub">Create a new organizational department.</p>
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm ms-auto">
                <i class="fa-solid fa-arrow-left me-1"></i>Back
            </a>
        </div>

        <div class="form-card">
            <form asp-action="Create" method="post">

                <div class="form-field-group mb-4">
                    <div class="form-section-label">
                        <i class="fa-solid fa-hashtag"></i> Identification
                    </div>
                    <div class="mb-3">
                        <label asp-for="Code" class="form-label form-label-custom">Department Code</label>
                        <input asp-for="Code" class="form-control form-control-custom" placeholder="e.g. DEPT-HR" />
                        <span asp-validation-for="Code" class="field-error"></span>
                    </div>
                    <div>
                        <label asp-for="Name" class="form-label form-label-custom">Department Name</label>
                        <input asp-for="Name" class="form-control form-control-custom" placeholder="e.g. Human Resources" />
                        <span asp-validation-for="Name" class="field-error"></span>
                    </div>
                </div>

                <div class="form-field-group mb-5">
                    <div class="form-section-label">
                        <i class="fa-solid fa-align-left"></i> Details
                    </div>
                    <label asp-for="Description" class="form-label form-label-custom">Description</label>
                    <textarea asp-for="Description" class="form-control form-control-custom" rows="3" placeholder="Optional description of this department..."></textarea>
                    <span asp-validation-for="Description" class="field-error"></span>
                </div>

                <div class="form-actions">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary px-5">
                        <i class="fa-solid fa-floppy-disk me-2"></i>Save Department
                    </button>
                </div>
            </form>
        </div>

    </div>
</div>
