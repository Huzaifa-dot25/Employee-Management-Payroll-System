@model EMPS.Web.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

@if (User.IsInRole("Employee"))
{
    <!-- Employee Premium Dashboard -->
    <div class="row g-4 mb-4">
        <!-- Live Clock & Attendance Control Widget -->
        <div class="col-12 col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); color: #f8fafc;">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <span class="badge bg-primary px-3 py-2 rounded-pill fw-semibold">Attendance Desk</span>
                            <span class="text-muted" style="font-size: 0.85rem;"><i class="fa-regular fa-calendar-days me-1"></i> <span id="dashboard-date">@DateTime.Today.ToString("dddd, MMMM dd")</span></span>
                        </div>
                        <div class="text-center my-3">
                            <div class="display-3 fw-bold tracking-tight mb-1" id="dashboard-clock" style="font-family: 'Outfit', sans-serif;">00:00:00 AM</div>
                            <p class="text-muted small">Standard Check-In time is 9:00 AM</p>
                        </div>
                    </div>

                    <div class="p-3 rounded-3 mb-3" style="background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1);">
                        <div class="row text-center g-2">
                            <div class="col-6">
                                <div class="small text-muted mb-1">Check In Time</div>
                                <div class="fw-semibold text-success">
                                    <i class="fa-solid fa-right-to-bracket me-1"></i> @(Model.CheckedInToday ? Model.CheckInTime : "—")
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="small text-muted mb-1">Check Out Time</div>
                                <div class="fw-semibold text-danger">
                                    <i class="fa-solid fa-right-from-bracket me-1"></i> @(Model.CheckedOutToday ? Model.CheckOutTime : "—")
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-3 justify-content-center">
                        @if (!Model.CheckedInToday)
                        {
                            <form asp-controller="Attendance" asp-action="CheckIn" method="post" class="w-100">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success w-100 py-3 rounded-3 fw-bold shadow-lg d-flex align-items-center justify-content-center gap-2">
                                    <i class="fa-solid fa-fingerprint fs-4"></i> Check In
                                </button>
                            </form>
                        }
                        else if (!Model.CheckedOutToday)
                        {
                            <form asp-controller="Attendance" asp-action="CheckOut" method="post" class="w-100">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-warning w-100 py-3 rounded-3 fw-bold shadow-lg text-white d-flex align-items-center justify-content-center gap-2">
                                    <i class="fa-solid fa-arrow-right-from-bracket fs-5"></i> Check Out
                                </button>
                            </form>
                        }
                        else
                        {
                            <button class="btn btn-secondary w-100 py-3 rounded-3 fw-bold border-0 cursor-not-allowed d-flex align-items-center justify-content-center gap-2" disabled>
                                <i class="fa-solid fa-circle-check fs-5 text-success"></i> Work Finished Today
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Employee Stats Summary Cards -->
        <div class="col-12 col-lg-6">
            <div class="row g-3 h-100">
                <div class="col-6">
                    <div class="card border-0 shadow-sm rounded-4 p-4 h-100 bg-white">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="text-muted fw-semibold small">Present Days</span>
                            <div class="bg-success-subtle text-success rounded-3 p-2"><i class="fa-solid fa-calendar-check"></i></div>
                        </div>
                        <h3 class="fw-bold mb-0">@Model.PresentDays</h3>
                        <span class="text-success small fw-semibold"><i class="fa-solid fa-check me-1"></i>This Month</span>
                    </div>
                </div>
                <div class="col-6">
                    <div class="card border-0 shadow-sm rounded-4 p-4 h-100 bg-white">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="text-muted fw-semibold small">Late Arrivals</span>
                            <div class="bg-warning-subtle text-warning rounded-3 p-2"><i class="fa-solid fa-clock"></i></div>
                        </div>
                        <h3 class="fw-bold mb-0">@Model.LateDays</h3>
                        <span class="text-warning small fw-semibold"><i class="fa-solid fa-triangle-exclamation me-1"></i>Be punctual</span>
                    </div>
                </div>
                <div class="col-6">
                    <div class="card border-0 shadow-sm rounded-4 p-4 h-100 bg-white">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="text-muted fw-semibold small">Leave Days</span>
                            <div class="bg-info-subtle text-info rounded-3 p-2"><i class="fa-solid fa-umbrella-beach"></i></div>
                        </div>
                        <h3 class="fw-bold mb-0">@Model.LeaveDays</h3>
                        <span class="text-info small fw-semibold"><i class="fa-solid fa-circle-info me-1"></i>Approved leaves</span>
                    </div>
                </div>
                <div class="col-6">
                    <div class="card border-0 shadow-sm rounded-4 p-4 h-100 bg-white">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="text-muted fw-semibold small">Avg Hours</span>
                            <div class="bg-primary-subtle text-primary rounded-3 p-2"><i class="fa-solid fa-business-time"></i></div>
                        </div>
                        <h3 class="fw-bold mb-0">@Model.AvgWorkingHours h</h3>
                        <span class="text-muted small fw-semibold"><i class="fa-solid fa-calculator me-1"></i>Standard 8h Shift</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts and Tables -->
    <div class="row g-4 mb-5">
        <!-- Weekly Working Hours Chart -->
        <div class="col-12 col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 bg-white h-100">
                <div class="card-header border-0 bg-transparent pt-4 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="m-0 fw-bold text-dark"><i class="fa-solid fa-chart-bar text-primary me-2"></i>Weekly Working Hours</h5>
                    <span class="text-muted small">Last 7 Days</span>
                </div>
                <div class="card-body p-4">
                    <canvas id="weeklyHoursChart" style="max-height: 280px;"></canvas>
                </div>
            </div>
        </div>

        <!-- Attendance Stats Chart -->
        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 bg-white h-100">
                <div class="card-header border-0 bg-transparent pt-4 px-4">
                    <h5 class="m-0 fw-bold text-dark"><i class="fa-solid fa-chart-pie text-success me-2"></i>Attendance Breakdown</h5>
                </div>
                <div class="card-body p-4 d-flex flex-column align-items-center justify-content-center">
                    <div style="max-width: 200px; width: 100%;">
                        <canvas id="attendanceBreakdownChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Leaves and History List -->
    <div class="row g-4">
        <!-- Leave Requests Widget -->
        <div class="col-12 col-xl-6">
            <div class="card border-0 shadow-sm rounded-4 bg-white">
                <div class="card-header border-0 bg-transparent pt-4 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="m-0 fw-bold text-dark"><i class="fa-solid fa-umbrella-beach text-success me-2"></i>My Leave Requests</h5>
                    <a asp-controller="Leave" asp-action="Index" class="btn btn-sm btn-light rounded-pill px-3">View All</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" style="font-size: 0.9rem;">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Leave Type</th>
                                    <th>Start Date</th>
                                    <th>End Date</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.RecentLeaves.Any())
                                {
                                    foreach (var leave in Model.RecentLeaves)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-semibold text-dark">@leave.LeaveType</td>
                                            <td>@leave.StartDate.ToString("MMM dd, yyyy")</td>
                                            <td>@leave.EndDate.ToString("MMM dd, yyyy")</td>
                                            <td>
                                                @if (leave.Status == "Approved")
                                                { <span class="badge bg-success-subtle text-success px-2.5 py-1.5 rounded-pill">Approved</span> }
                                                else if (leave.Status == "Rejected")
                                                { <span class="badge bg-danger-subtle text-danger px-2.5 py-1.5 rounded-pill">Rejected</span> }
                                                else
                                                { <span class="badge bg-warning-subtle text-warning px-2.5 py-1.5 rounded-pill">Pending</span> }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-muted">No leave requests found.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Logs Widget -->
        <div class="col-12 col-xl-6">
            <div class="card border-0 shadow-sm rounded-4 bg-white">
                <div class="card-header border-0 bg-transparent pt-4 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="m-0 fw-bold text-dark"><i class="fa-solid fa-list-check text-info me-2"></i>My Recent Records</h5>
                    <a asp-controller="Attendance" asp-action="Index" class="btn btn-sm btn-light rounded-pill px-3">View Log</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" style="font-size: 0.9rem;">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Date</th>
                                    <th>Check In</th>
                                    <th>Check Out</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var recentLogs = (Model.RecentEmployees != null) ? new List<string>() : new List<string>();
                                }
                                <tr class="border-0">
                                    <td colspan="4" class="p-0">
                                        <div class="alert alert-light border-0 m-2 text-center text-muted" style="font-size: 0.85rem;">
                                            <i class="fa-solid fa-info-circle me-1 text-info"></i> For full histories, please navigate to the Attendance page history tab.
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <!-- Admin & HR Premium Dashboard -->
    <div class="row g-4 mb-5">
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card-stat shadow-sm border-0 bg-white p-4 rounded-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="card-stat-title text-muted fw-semibold mb-1">Total Employees</h6>
                        <h3 class="card-stat-value fw-bold text-dark mb-0">@Model.TotalEmployees</h3>
                    </div>
                    <div class="card-stat-icon bg-primary-subtle text-primary rounded-3 p-3">
                        <i class="fa-solid fa-users fs-4"></i>
                    </div>
                </div>
                <div class="mt-3 text-muted" style="font-size: 0.8rem;">
                    <i class="fa-solid fa-arrow-trend-up text-success me-1"></i>
                    <span>Active: <strong>@Model.ActiveEmployees</strong></span>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card-stat shadow-sm border-0 bg-white p-4 rounded-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="card-stat-title text-muted fw-semibold mb-1">Present Today</h6>
                        <h3 class="card-stat-value fw-bold text-success mb-0">@Model.PresentToday</h3>
                    </div>
                    <div class="card-stat-icon bg-success-subtle text-success rounded-3 p-3">
                        <i class="fa-solid fa-user-check fs-4"></i>
                    </div>
                </div>
                <div class="mt-3 text-muted" style="font-size: 0.8rem;">
                    <i class="fa-solid fa-clock-rotate-left me-1"></i>
                    <span>Daily attendance log</span>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card-stat shadow-sm border-0 bg-white p-4 rounded-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="card-stat-title text-muted fw-semibold mb-1">Pending Leaves</h6>
                        <h3 class="card-stat-value fw-bold text-warning mb-0">@Model.PendingLeaveRequests</h3>
                    </div>
                    <div class="card-stat-icon bg-warning-subtle text-warning rounded-3 p-3">
                        <i class="fa-solid fa-plane-arrival fs-4"></i>
                    </div>
                </div>
                <div class="mt-3 text-muted" style="font-size: 0.8rem;">
                    @if (Model.PendingLeaveRequests > 0)
                    {
                        <span class="text-danger fw-semibold"><i class="fa-solid fa-circle-exclamation me-1"></i>Action required</span>
                    }
                    else
                    {
                        <span>All requests processed</span>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card-stat shadow-sm border-0 bg-white p-4 rounded-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="card-stat-title text-muted fw-semibold mb-1">Salary Paid</h6>
                        <h3 class="card-stat-value fw-bold text-dark mb-0">$@Model.TotalSalaryPaid.ToString("N0")</h3>
                    </div>
                    <div class="card-stat-icon bg-info-subtle text-info rounded-3 p-3">
                        <i class="fa-solid fa-circle-dollar-to-slot fs-4"></i>
                    </div>
                </div>
                <div class="mt-3 text-muted" style="font-size: 0.8rem;">
                    <i class="fa-solid fa-chart-line text-success me-1"></i>
                    <span>All-time net payroll</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Section -->
    <div class="row g-4 mb-5">
        <!-- Weekly Attendance Trend Chart -->
        <div class="col-12 col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 bg-white h-100">
                <div class="card-header border-0 bg-transparent pt-4 px-4">
                    <h5 class="m-0 fw-bold text-dark"><i class="fa-solid fa-calendar-week text-success me-2"></i>Weekly Attendance Trend</h5>
                </div>
                <div class="card-body p-4">
                    <canvas id="weeklyAttendanceChart" style="max-height: 300px;"></canvas>
                </div>
            </div>
        </div>

        <!-- Payroll Analytics Chart -->
        <div class="col-12 col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 bg-white h-100">
                <div class="card-header border-0 bg-transparent pt-4 px-4">
                    <h5 class="m-0 fw-bold text-dark"><i class="fa-solid fa-chart-simple text-primary me-2"></i>Payroll Payout Analytics</h5>
                </div>
                <div class="card-body p-4">
                    <canvas id="payrollChart" style="max-height: 300px;"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Tables Row -->
    <div class="row g-4">
        <!-- Recently Joined Employees -->
        <div class="col-12 col-xl-6">
            <div class="card border-0 shadow-sm rounded-4 bg-white">
                <div class="card-header border-0 bg-transparent pt-4 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="m-0 fw-bold text-dark"><i class="fa-solid fa-user-plus text-primary me-2"></i>Recently Joined Employees</h5>
                    <a asp-controller="Employee" asp-action="Index" class="btn btn-sm btn-light rounded-pill px-3">View All</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" style="font-size: 0.9rem;">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Employee</th>
                                    <th>Code</th>
                                    <th>Department</th>
                                    <th>Joined</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.RecentEmployees.Any())
                                {
                                    foreach (var emp in Model.RecentEmployees)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <div class="d-flex align-items-center gap-3">
                                                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 32px; height: 32px; font-size: 0.8rem;">
                                                        @emp.FirstName.Substring(0, 1).ToUpper()
                                                    </div>
                                                    <span class="fw-semibold text-dark">@emp.FullName</span>
                                                </div>
                                            </td>
                                            <td><code>@emp.EmployeeCode</code></td>
                                            <td>@emp.DepartmentName</td>
                                            <td>@emp.JoiningDate.ToString("MMM dd, yyyy")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-muted">No employees registered yet.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Leave Requests -->
        <div class="col-12 col-xl-6">
            <div class="card border-0 shadow-sm rounded-4 bg-white">
                <div class="card-header border-0 bg-transparent pt-4 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="m-0 fw-bold text-dark"><i class="fa-solid fa-umbrella-beach text-success me-2"></i>Recent Leave Requests</h5>
                    <a asp-controller="Leave" asp-action="Index" class="btn btn-sm btn-light rounded-pill px-3">View All</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" style="font-size: 0.9rem;">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Employee</th>
                                    <th>Type</th>
                                    <th>Duration</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.RecentLeaves.Any())
                                {
                                    foreach (var leave in Model.RecentLeaves)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-semibold text-dark">@leave.EmployeeName</td>
                                            <td>@leave.LeaveType</td>
                                            <td>@leave.StartDate.ToString("MM/dd") - @leave.EndDate.ToString("MM/dd")</td>
                                            <td>
                                                @if (leave.Status == "Approved")
                                                { <span class="badge bg-success-subtle text-success px-2.5 py-1.5 rounded-pill">Approved</span> }
                                                else if (leave.Status == "Rejected")
                                                { <span class="badge bg-danger-subtle text-danger px-2.5 py-1.5 rounded-pill">Rejected</span> }
                                                else
                                                { <span class="badge bg-warning-subtle text-warning px-2.5 py-1.5 rounded-pill">Pending</span> }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-muted">No leave requests registered yet.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <!-- Chart.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    @if (User.IsInRole("Employee"))
    {
        <script>
            $(document).ready(function () {
                // Real-time Clock Logic
                function updateClock() {
                    const now = new Date();
                    let hours = now.getHours();
                    let minutes = now.getMinutes();
                    let seconds = now.getSeconds();
                    const ampm = hours >= 12 ? 'PM' : 'AM';
                    
                    hours = hours % 12;
                    hours = hours ? hours : 12; // the hour '0' should be '12'
                    minutes = minutes < 10 ? '0' + minutes : minutes;
                    seconds = seconds < 10 ? '0' + seconds : seconds;
                    
                    const timeString = `${hours}:${minutes}:${seconds} ${ampm}`;
                    $('#dashboard-clock').text(timeString);
                }
                updateClock();
                setInterval(updateClock, 1000);

                // Employee Weekly Hours Chart
                const whCtx = document.getElementById('weeklyHoursChart').getContext('2d');
                const whLabels = @Html.Raw(Json.Serialize(Model.WeeklyWorkingHoursLabels));
                const whData = @Html.Raw(Json.Serialize(Model.WeeklyWorkingHoursData));

                new Chart(whCtx, {
                    type: 'line',
                    data: {
                        labels: whLabels,
                        datasets: [{
                            label: 'Hours Worked',
                            data: whData,
                            borderColor: '#6366f1',
                            backgroundColor: 'rgba(99, 102, 241, 0.1)',
                            borderWidth: 3,
                            fill: true,
                            tension: 0.3
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            y: { beginAtZero: true, max: 12, ticks: { stepSize: 2 } }
                        }
                    }
                });

                // Employee Attendance Breakdown Pie Chart
                const piCtx = document.getElementById('attendanceBreakdownChart').getContext('2d');
                new Chart(piCtx, {
                    type: 'doughnut',
                    data: {
                        labels: ['Present', 'Absent', 'Late', 'Leave'],
                        datasets: [{
                            data: [@Model.PresentDays, @Model.AbsentDays, @Model.LateDays, @Model.LeaveDays],
                            backgroundColor: ['#10b981', '#ef4444', '#f59e0b', '#06b6d4'],
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { position: 'bottom' } }
                    }
                });
            });
        </script>
    }
    else
    {
        <script>
            $(document).ready(function () {
                // Admin Weekly Attendance Chart
                const waCtx = document.getElementById('weeklyAttendanceChart').getContext('2d');
                const waLabels = @Html.Raw(Json.Serialize(Model.WeeklyAttendanceLabels));
                const presentData = @Html.Raw(Json.Serialize(Model.WeeklyPresentData));
                const absentData = @Html.Raw(Json.Serialize(Model.WeeklyAbsentData));
                const lateData = @Html.Raw(Json.Serialize(Model.WeeklyLateData));
                const leaveData = @Html.Raw(Json.Serialize(Model.WeeklyLeaveData));

                new Chart(waCtx, {
                    type: 'bar',
                    data: {
                        labels: waLabels,
                        datasets: [
                            { label: 'Present', data: presentData, backgroundColor: '#10b981' },
                            { label: 'Absent', data: absentData, backgroundColor: '#ef4444' },
                            { label: 'Late', data: lateData, backgroundColor: '#f59e0b' },
                            { label: 'Leave', data: leaveData, backgroundColor: '#06b6d4' }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            x: { stacked: true },
                            y: { stacked: true, beginAtZero: true }
                        }
                    }
                });

                // Admin Payroll Payout Analytics Chart
                const prCtx = document.getElementById('payrollChart').getContext('2d');
                const prLabels = @Html.Raw(Json.Serialize(Model.MonthlyLabels));
                const prData = @Html.Raw(Json.Serialize(Model.MonthlySalaryPayouts));

                new Chart(prCtx, {
                    type: 'line',
                    data: {
                        labels: prLabels,
                        datasets: [{
                            label: 'Net Payout ($)',
                            data: prData,
                            borderColor: '#4f46e5',
                            backgroundColor: 'rgba(79, 70, 229, 0.1)',
                            borderWidth: 3,
                            fill: true,
                            tension: 0.4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } }
                    }
                });
            });
        </script>
    }
}




