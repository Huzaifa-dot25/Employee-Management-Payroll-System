@model EMPS.Web.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Stats Overview Grid -->
<div class="row g-4 mb-5">
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card-stat">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="card-stat-title">Total Employees</h6>
                    <h3 class="card-stat-value">@Model.TotalEmployees</h3>
                </div>
                <div class="card-stat-icon bg-primary-subtle text-primary">
                    <i class="fa-solid fa-users"></i>
                </div>
            </div>
            <div class="mt-3 text-muted" style="font-size: 0.8rem;">
                <i class="fa-solid fa-arrow-trend-up text-success me-1"></i>
                <span>Active: <strong>@Model.ActiveEmployees</strong></span>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card-stat">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="card-stat-title">Salary Paid</h6>
                    <h3 class="card-stat-value">$@Model.TotalSalaryPaid.ToString("N2")</h3>
                </div>
                <div class="card-stat-icon bg-success-subtle text-success">
                    <i class="fa-solid fa-circle-dollar-to-slot"></i>
                </div>
            </div>
            <div class="mt-3 text-muted" style="font-size: 0.8rem;">
                <i class="fa-solid fa-chart-line text-success me-1"></i>
                <span>All-time net payroll</span>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card-stat">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="card-stat-title">Present Today</h6>
                    <h3 class="card-stat-value">@Model.PresentToday</h3>
                </div>
                <div class="card-stat-icon bg-info-subtle text-info">
                    <i class="fa-solid fa-user-check"></i>
                </div>
            </div>
            <div class="mt-3 text-muted" style="font-size: 0.8rem;">
                <i class="fa-solid fa-clock-rotate-left me-1"></i>
                <span>Daily attendance log</span>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card-stat">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="card-stat-title">Pending Leaves</h6>
                    <h3 class="card-stat-value text-warning">@Model.PendingLeaveRequests</h3>
                </div>
                <div class="card-stat-icon bg-warning-subtle text-warning">
                    <i class="fa-solid fa-plane-arrival"></i>
                </div>
            </div>
            <div class="mt-3 text-muted" style="font-size: 0.8rem;">
                @if (Model.PendingLeaveRequests > 0)
                {
                    <span class="text-danger fw-semibold"><i class="fa-solid fa-circle-exclamation me-1"></i>Requires approval</span>
                }
                else
                {
                    <span>All requests processed</span>
                }
            </div>
        </div>
    </div>
</div>

<!-- Charts and Activity Area -->
<div class="row g-4 mb-5">
    <!-- Payroll Analytics Chart -->
    <div class="col-12 col-lg-8">
        <div class="card-flat h-100">
            <div class="card-flat-header">
                <h5 class="m-0 fw-bold"><i class="fa-solid fa-chart-simple text-primary me-2"></i>Payroll Payout Analytics</h5>
            </div>
            <div class="card-flat-body">
                <canvas id="payrollChart" style="max-height: 320px;"></canvas>
            </div>
        </div>
    </div>

    <!-- Quick Info Cards -->
    <div class="col-12 col-lg-4">
        <div class="card-flat h-100">
            <div class="card-flat-header">
                <h5 class="m-0 fw-bold"><i class="fa-solid fa-bell text-warning me-2"></i>Dashboard Alerts</h5>
            </div>
            <div class="card-flat-body">
                <div class="d-flex flex-column gap-3">
                    @if (Model.PendingLeaveRequests > 0)
                    {
                        <div class="alert alert-warning border-0 d-flex align-items-start gap-3 m-0 shadow-sm">
                            <i class="fa-solid fa-plane-departure fs-5 mt-1"></i>
                            <div>
                                <h6 class="alert-heading fw-bold mb-1">Leave Approvals Pending</h6>
                                <p class="mb-0 text-muted" style="font-size: 0.85rem;">There are @Model.PendingLeaveRequests leave requests waiting for your decision.</p>
                                <a asp-controller="Leave" asp-action="Index" class="alert-link d-inline-block mt-2" style="font-size: 0.85rem;">Review Now <i class="fa-solid fa-arrow-right"></i></a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="fa-solid fa-clipboard-check fs-1 mb-3 text-secondary"></i>
                            <p class="mb-0">No urgent action items at this time.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Employee Table -->
<div class="row g-4">
    <div class="col-12 col-xl-6">
        <div class="card-flat">
            <div class="card-flat-header">
                <h5 class="m-0 fw-bold"><i class="fa-solid fa-user-plus text-primary me-2"></i>Recently Joined Employees</h5>
                <a asp-controller="Employee" asp-action="Index" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-flat-body p-0">
                <div class="table-responsive">
                    <table class="table table-custom">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Code</th>
                                <th>Department</th>
                                <th>Joined</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentEmployees.Any())
                            {
                                foreach (var emp in Model.RecentEmployees)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-3">
                                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; font-size: 0.8rem; font-weight: 600;">
                                                    @emp.FirstName.Substring(0, 1).ToUpper()
                                                </div>
                                                <span class="fw-semibold">@emp.FullName</span>
                                            </div>
                                        </td>
                                        <td><code>@emp.EmployeeCode</code></td>
                                        <td>@emp.DepartmentName</td>
                                        <td>@emp.JoiningDate.ToString("MMM dd, yyyy")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-4 text-muted">No employees registered yet.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Leaves Table -->
    <div class="col-12 col-xl-6">
        <div class="card-flat">
            <div class="card-flat-header">
                <h5 class="m-0 fw-bold"><i class="fa-solid fa-umbrella-beach text-success me-2"></i>Recent Leave Requests</h5>
                <a asp-controller="Leave" asp-action="Index" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-flat-body p-0">
                <div class="table-responsive">
                    <table class="table table-custom">
                        <thead>
                            <tr>
                                <th>Employee</th>
                                <th>Type</th>
                                <th>Duration</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentLeaves.Any())
                            {
                                foreach (var leave in Model.RecentLeaves)
                                {
                                    <tr>
                                        <td class="fw-semibold">@leave.EmployeeName</td>
                                        <td>@leave.LeaveType</td>
                                        <td>@leave.StartDate.ToString("MM/dd") - @leave.EndDate.ToString("MM/dd")</td>
                                        <td>
                                            @if (leave.Status == "Approved")
                                            {
                                                <span class="badge bg-success-subtle text-success badge-custom">Approved</span>
                                            }
                                            else if (leave.Status == "Rejected")
                                            {
                                                <span class="badge bg-danger-subtle text-danger badge-custom">Rejected</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning-subtle text-warning badge-custom">Pending</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-4 text-muted">No leave requests registered yet.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Chart.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        $(document).ready(function () {
            // Chart.js Configuration
            const ctx = document.getElementById('payrollChart').getContext('2d');
            
            const labels = @Html.Raw(Json.Serialize(Model.MonthlyLabels));
            const data = @Html.Raw(Json.Serialize(Model.MonthlySalaryPayouts));

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Net Payout ($)',
                        data: data,
                        borderColor: '#4f46e5',
                        backgroundColor: 'rgba(79, 70, 229, 0.1)',
                        borderWidth: 3,
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        }
                    },
                    scales: {
                        y: {
                            grid: {
                                color: '#f1f5f9'
                            },
                            ticks: {
                                color: '#64748b',
                                font: {
                                    family: "'Inter', sans-serif"
                                }
                            }
                        },
                        x: {
                            grid: {
                                display: false
                            },
                            ticks: {
                                color: '#64748b',
                                font: {
                                    family: "'Inter', sans-serif"
                                }
                            }
                        }
                    }
                }
            });
        });
    </script>
}
