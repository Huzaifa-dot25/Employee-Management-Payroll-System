@model IEnumerable<EMPS.Web.Models.AttendanceViewModel>
@{
    ViewData["Title"] = "Attendance";
    int present  = Model.Count(a => a.Status == "Present");
    int absent   = Model.Count(a => a.Status == "Absent");
    int onLeave  = Model.Count(a => a.Status == "Leave");
    int late     = Model.Count(a => a.Status == "Late" || a.Status == "HalfDay");
}

<div class="module-header">
    <div class="module-header-left">
        <div class="module-icon-wrap" style="background:linear-gradient(135deg,#10b981,#34d399);">
            <i class="fa-solid fa-calendar-check"></i>
        </div>
        <div>
            <h3 class="module-title">Attendance Log</h3>
            <p class="module-sub">Track and manage employee attendance records</p>
        </div>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("HR"))
    {
        <a asp-action="Create" class="btn-module-add">
            <i class="fa-solid fa-plus"></i>
            <span>Mark Attendance</span>
        </a>
    }
</div>

<div class="module-stats-strip mb-4">
    <div class="mss-item">
        <span class="mss-value text-success">@present</span>
        <span class="mss-label">Present</span>
    </div>
    <div class="mss-divider"></div>
    <div class="mss-item">
        <span class="mss-value text-danger">@absent</span>
        <span class="mss-label">Absent</span>
    </div>
    <div class="mss-divider"></div>
    <div class="mss-item">
        <span class="mss-value text-warning">@onLeave</span>
        <span class="mss-label">On Leave</span>
    </div>
    <div class="mss-divider"></div>
    <div class="mss-item">
        <span class="mss-value" style="color:#f97316;">@late</span>
        <span class="mss-label">Late / Half Day</span>
    </div>
</div>

<div class="data-table-card">
    <div class="table-responsive">
        <table class="table module-table w-100" id="attendanceTable">
            <thead>
                <tr>
                    @if (User.IsInRole("Admin") || User.IsInRole("HR"))
                    {
                        <th>Employee</th>
                    }
                    <th>Date</th>
                    <th>Status</th>
                    <th>Check In</th>
                    <th>Check Out</th>
                    <th>Remarks</th>
                    @if (User.IsInRole("Admin") || User.IsInRole("HR"))
                    {
                        <th class="text-end">Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        @if (User.IsInRole("Admin") || User.IsInRole("HR"))
                        {
                            <td><span class="row-primary-text">@item.EmployeeName</span></td>
                        }
                        <td><span class="date-text">@item.Date.ToString("MMM dd, yyyy")</span></td>
                        <td>
                            @if (item.Status == "Present")
                            {
                                <span class="status-badge status-active">Present</span>
                            }
                            else if (item.Status == "Absent")
                            {
                                <span class="status-badge status-terminated">Absent</span>
                            }
                            else if (item.Status == "Leave")
                            {
                                <span class="status-badge status-pending">Leave</span>
                            }
                            else
                            {
                                <span class="status-badge status-inactive">@item.Status</span>
                            }
                        </td>
                        <td>
                            @if (item.CheckInTime.HasValue)
                            {
                                <span class="time-chip time-in"><i class="fa-regular fa-clock"></i> @item.CheckInTime.Value.ToString(@"hh\:mm")</span>
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td>
                            @if (item.CheckOutTime.HasValue)
                            {
                                <span class="time-chip time-out"><i class="fa-regular fa-clock"></i> @item.CheckOutTime.Value.ToString(@"hh\:mm")</span>
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td><span class="text-muted" style="font-size:.8rem;">@(string.IsNullOrEmpty(item.Remarks) ? "—" : item.Remarks)</span></td>
                        @if (User.IsInRole("Admin") || User.IsInRole("HR"))
                        {
                            <td class="text-end">
                                <div class="action-btns">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="action-btn action-btn-edit" title="Edit">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                </div>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#attendanceTable').DataTable({
                responsive: true,
                order: [[@(User.IsInRole("Admin") || User.IsInRole("HR") ? 1 : 0), 'desc']],
                dom: "<'dt-toolbar'<'dt-toolbar-left'l><'dt-toolbar-right'f>>" +
                     "<'row'<'col-sm-12'tr>>" +
                     "<'dt-footer'<'dt-footer-left'i><'dt-footer-right'p>>",
                language: {
                    search: "",
                    searchPlaceholder: "🔍  Search attendance...",
                    lengthMenu: "Show _MENU_ rows",
                    info: "Showing _START_–_END_ of _TOTAL_ records",
                    paginate: { previous: "‹ Prev", next: "Next ›" }
                }
            });
        });
    </script>
}
