@model EMPS.Web.Models.MonthlyReportViewModel
@{
    ViewData["Title"] = "Monthly Attendance Report";
    var monthName = new DateTime(Model.Year, Model.Month, 1).ToString("MMMM yyyy");
}

<div class="module-header">
    <div class="module-header-left">
        <div class="module-icon-wrap" style="background:linear-gradient(135deg,#7c3aed,#a78bfa);">
            <i class="fa-solid fa-chart-bar"></i>
        </div>
        <div>
            <h3 class="module-title">Monthly Attendance Report</h3>
            <p class="module-sub">Summary of employee attendance for <strong>@monthName</strong> &mdash; @Model.DepartmentName</p>
        </div>
    </div>
</div>

<ul class="nav nav-tabs mb-4" style="border-bottom:2px solid #e5e7eb;">
    <li class="nav-item">
        <a class="nav-link" asp-action="Index">
            <i class="fa-solid fa-list me-1"></i>Attendance Log
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" asp-action="Daily">
            <i class="fa-solid fa-calendar-day me-1"></i>Daily
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link active fw-semibold" asp-action="MonthlyReport">
            <i class="fa-solid fa-chart-bar me-1"></i>Monthly Report
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" asp-action="EmployeeHistory">
            <i class="fa-solid fa-clock-rotate-left me-1"></i>Employee History
        </a>
    </li>
</ul>

<div class="data-table-card mb-4 p-3">
    <form method="get" asp-action="MonthlyReport" class="row g-3 align-items-end">
        <div class="col-12 col-md-3">
            <label class="form-label fw-semibold">Month</label>
            <select name="month" class="form-select">
                @for (int m = 1; m <= 12; m++)
                {
                    var mName = new DateTime(2000, m, 1).ToString("MMMM");
                    if (m == Model.Month)
                    { <option value="@m" selected>@mName</option> }
                    else
                    { <option value="@m">@mName</option> }
                }
            </select>
        </div>
        <div class="col-12 col-md-2">
            <label class="form-label fw-semibold">Year</label>
            <select name="year" class="form-select">
                @for (int y = DateTime.Today.Year - 3; y <= DateTime.Today.Year + 1; y++)
                {
                    if (y == Model.Year)
                    { <option value="@y" selected>@y</option> }
                    else
                    { <option value="@y">@y</option> }
                }
            </select>
        </div>
        <div class="col-12 col-md-3">
            <label class="form-label fw-semibold">Department</label>
            <select name="departmentId" class="form-select">
                <option value="">All Departments</option>
                @foreach (SelectListItem dept in ViewBag.Departments)
                {
                    if (dept.Selected)
                    { <option value="@dept.Value" selected>@dept.Text</option> }
                    else
                    { <option value="@dept.Value">@dept.Text</option> }
                }
            </select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary px-4">
                <i class="fa-solid fa-magnifying-glass me-2"></i>Generate
            </button>
        </div>
    </form>
</div>

<div class="module-stats-strip mb-4">
    <div class="mss-item">
        <span class="mss-value">@Model.Rows.Count</span>
        <span class="mss-label">Employees</span>
    </div>
    <div class="mss-divider"></div>
    <div class="mss-item">
        <span class="mss-value text-success">@Model.TotalPresent</span>
        <span class="mss-label">Total Present Days</span>
    </div>
    <div class="mss-divider"></div>
    <div class="mss-item">
        <span class="mss-value text-danger">@Model.TotalAbsent</span>
        <span class="mss-label">Total Absent Days</span>
    </div>
    <div class="mss-divider"></div>
    <div class="mss-item">
        <span class="mss-value text-warning">@Model.TotalLeave</span>
        <span class="mss-label">Total Leave Days</span>
    </div>
    <div class="mss-divider"></div>
    <div class="mss-item">
        <span class="mss-value" style="color:#f97316;">@Model.TotalLate</span>
        <span class="mss-label">Total Late Days</span>
    </div>
</div>

@if (!Model.Rows.Any())
{
    <div class="alert alert-info">
        <i class="fa-solid fa-circle-info me-2"></i>
        No attendance data found for <strong>@monthName</strong>.
    </div>
}
else
{
    <div class="data-table-card">
        <div class="table-responsive">
            <table class="table module-table w-100" id="monthlyTable">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Code</th>
                        <th>Department</th>
                        <th class="text-center text-success">Present</th>
                        <th class="text-center text-danger">Absent</th>
                        <th class="text-center text-warning">Leave</th>
                        <th class="text-center" style="color:#f97316;">Late</th>
                        <th class="text-center" style="color:#8b5cf6;">Half Day</th>
                        <th class="text-center">Attendance %</th>
                        <th class="text-end">History</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Rows)
                    {
                        string rateClass = row.AttendanceRate >= 90 ? "text-success"
                                         : row.AttendanceRate >= 70 ? "text-warning"
                                         : "text-danger";
                        <tr>
                            <td><span class="row-primary-text">@row.EmployeeName</span></td>
                            <td><span class="text-sub">@row.EmployeeCode</span></td>
                            <td><span class="text-sub">@row.Department</span></td>
                            <td class="text-center"><span class="fw-bold text-success">@row.PresentDays</span></td>
                            <td class="text-center"><span class="fw-bold text-danger">@row.AbsentDays</span></td>
                            <td class="text-center"><span class="fw-bold text-warning">@row.LeaveDays</span></td>
                            <td class="text-center"><span class="fw-bold" style="color:#f97316;">@row.LateDays</span></td>
                            <td class="text-center"><span class="fw-bold" style="color:#8b5cf6;">@row.HalfDays</span></td>
                            <td class="text-center">
                                <div class="d-flex align-items-center gap-2 justify-content-center">
                                    <div style="width:60px;height:6px;background:#e5e7eb;border-radius:3px;overflow:hidden;">
                                        <div style="width:@(row.AttendanceRate)%;height:100%;background:@(row.AttendanceRate >= 90 ? "#10b981" : row.AttendanceRate >= 70 ? "#f59e0b" : "#ef4444");border-radius:3px;"></div>
                                    </div>
                                    <span class="fw-semibold @rateClass" style="font-size:.85rem;">@row.AttendanceRate%</span>
                                </div>
                            </td>
                            <td class="text-end">
                                <a asp-action="EmployeeHistory" asp-route-employeeId="@row.EmployeeId"
                                   class="action-btn action-btn-view" title="View Full History">
                                    <i class="fa-solid fa-clock-rotate-left"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#monthlyTable').DataTable({
                responsive: true,
                order: [[0, 'asc']],
                dom: "<'dt-toolbar'<'dt-toolbar-left'l><'dt-toolbar-right'f>>" +
                     "<'row'<'col-sm-12'tr>>" +
                     "<'dt-footer'<'dt-footer-left'i><'dt-footer-right'p>>",
                language: {
                    search: "",
                    searchPlaceholder: "🔍  Search employees...",
                    lengthMenu: "Show _MENU_ rows",
                    info: "Showing _START_–_END_ of _TOTAL_ employees",
                    paginate: { previous: "‹ Prev", next: "Next ›" }
                }
            });
        });
    </script>
}
