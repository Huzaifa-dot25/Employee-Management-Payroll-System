@model EMPS.Web.Models.DailyAttendanceViewModel
@{
    ViewData["Title"] = "Daily Attendance";
    string fmtDate = Model.Date.ToString("dddd, MMMM dd yyyy");
}

<div class="module-header">
    <div class="module-header-left">
        <div class="module-icon-wrap" style="background:linear-gradient(135deg,#0ea5e9,#38bdf8);">
            <i class="fa-solid fa-calendar-day"></i>
        </div>
        <div>
            <h3 class="module-title">Daily Attendance</h3>
            <p class="module-sub">View who's present, absent, or on leave for a specific day</p>
        </div>
    </div>
    <a asp-action="Create" class="btn-module-add">
        <i class="fa-solid fa-plus"></i>
        <span>Mark Attendance</span>
    </a>
</div>

<ul class="nav nav-tabs mb-4" style="border-bottom:2px solid #e5e7eb;">
    <li class="nav-item">
        <a class="nav-link" asp-action="Index">
            <i class="fa-solid fa-list me-1"></i>Attendance Log
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link active fw-semibold" asp-action="Daily">
            <i class="fa-solid fa-calendar-day me-1"></i>Daily
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" asp-action="MonthlyReport">
            <i class="fa-solid fa-chart-bar me-1"></i>Monthly Report
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" asp-action="EmployeeHistory">
            <i class="fa-solid fa-clock-rotate-left me-1"></i>Employee History
        </a>
    </li>
</ul>

<div class="data-table-card mb-4 p-3">
    <form method="get" asp-action="Daily" class="row g-3 align-items-end">
        <div class="col-12 col-md-4">
            <label class="form-label fw-semibold">Select Date</label>
            <input type="date" name="date" class="form-control"
                   value="@Model.Date.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary px-4">
                <i class="fa-solid fa-magnifying-glass me-2"></i>View
            </button>
        </div>
        <div class="col-auto ms-auto align-self-center">
            <span class="fw-semibold text-muted">@fmtDate</span>
        </div>
    </form>
</div>

<div class="module-stats-strip mb-4">
    <div class="mss-item">
        <span class="mss-value">@Model.TotalCount</span>
        <span class="mss-label">Total Records</span>
    </div>
    <div class="mss-divider"></div>
    <div class="mss-item">
        <span class="mss-value text-success">@Model.PresentCount</span>
        <span class="mss-label">Present</span>
    </div>
    <div class="mss-divider"></div>
    <div class="mss-item">
        <span class="mss-value text-danger">@Model.AbsentCount</span>
        <span class="mss-label">Absent</span>
    </div>
    <div class="mss-divider"></div>
    <div class="mss-item">
        <span class="mss-value text-warning">@Model.LeaveCount</span>
        <span class="mss-label">On Leave</span>
    </div>
    <div class="mss-divider"></div>
    <div class="mss-item">
        <span class="mss-value" style="color:#f97316;">@Model.LateCount</span>
        <span class="mss-label">Late</span>
    </div>
    <div class="mss-divider"></div>
    <div class="mss-item">
        <span class="mss-value" style="color:#8b5cf6;">@Model.HalfDayCount</span>
        <span class="mss-label">Half Day</span>
    </div>
</div>

@if (!Model.Records.Any())
{
    <div class="alert alert-info">
        <i class="fa-solid fa-circle-info me-2"></i>
        No attendance records found for <strong>@fmtDate</strong>.
        <a asp-action="Create" class="alert-link ms-2">Mark attendance now &rarr;</a>
    </div>
}
else
{
    <div class="data-table-card">
        <div class="table-responsive">
            <table class="table module-table w-100" id="dailyTable">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Status</th>
                        <th>Check In</th>
                        <th>Check Out</th>
                        <th>Hours</th>
                        <th>Remarks</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Records)
                    {
                        double? hours = null;
                        if (item.CheckInTime.HasValue && item.CheckOutTime.HasValue)
                            hours = (item.CheckOutTime.Value - item.CheckInTime.Value).TotalHours;

                        <tr>
                            <td><span class="row-primary-text">@item.EmployeeName</span></td>
                            <td>
                                @if (item.Status == "Present")
                                { <span class="status-badge status-active">Present</span> }
                                else if (item.Status == "Absent")
                                { <span class="status-badge status-terminated">Absent</span> }
                                else if (item.Status == "Leave")
                                { <span class="status-badge status-pending">Leave</span> }
                                else
                                { <span class="status-badge status-inactive">@item.Status</span> }
                            </td>
                            <td>
                                @if (item.CheckInTime.HasValue)
                                { <span class="time-chip time-in"><i class="fa-regular fa-clock"></i> @item.CheckInTime.Value.ToString(@"hh\:mm")</span> }
                                else { <span class="text-muted">—</span> }
                            </td>
                            <td>
                                @if (item.CheckOutTime.HasValue)
                                { <span class="time-chip time-out"><i class="fa-regular fa-clock"></i> @item.CheckOutTime.Value.ToString(@"hh\:mm")</span> }
                                else { <span class="text-muted">—</span> }
                            </td>
                            <td>
                                @if (hours.HasValue)
                                { <span class="text-sub">@hours.Value.ToString("F1")h</span> }
                                else { <span class="text-muted">—</span> }
                            </td>
                            <td><span class="text-muted" style="font-size:.8rem;">@(string.IsNullOrEmpty(item.Remarks) ? "—" : item.Remarks)</span></td>
                            <td class="text-end">
                                <div class="action-btns">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="action-btn action-btn-edit" title="Edit">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#dailyTable').DataTable({
                responsive: true,
                order: [[0, 'asc']],
                dom: "<'dt-toolbar'<'dt-toolbar-left'l><'dt-toolbar-right'f>>" +
                     "<'row'<'col-sm-12'tr>>" +
                     "<'dt-footer'<'dt-footer-left'i><'dt-footer-right'p>>",
                language: {
                    search: "",
                    searchPlaceholder: "🔍  Search...",
                    lengthMenu: "Show _MENU_ rows",
                    info: "Showing _START_–_END_ of _TOTAL_ records",
                    paginate: { previous: "‹ Prev", next: "Next ›" }
                }
            });
        });
    </script>
}
