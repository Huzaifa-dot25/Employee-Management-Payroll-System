@model EMPS.Web.Models.DesignationViewModel
@{
    ViewData["Title"] = "Edit Designation";
}

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">

        <div class="form-page-header mb-4">
            <div class="form-page-icon"><i class="fa-solid fa-briefcase"></i></div>
            <div>
                <h4 class="form-page-title">Edit Designation</h4>
                <p class="form-page-sub">Update job title details and compensation.</p>
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm ms-auto">
                <i class="fa-solid fa-arrow-left me-1"></i>Back
            </a>
        </div>

        <div class="form-card">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="form-field-group mb-4">
                    <div class="form-section-label">
                        <i class="fa-solid fa-sitemap"></i> Organization
                    </div>
                    <div class="mb-3">
                        <label asp-for="DepartmentId" class="form-label form-label-custom">Department</label>
                        <select asp-for="DepartmentId" class="form-select form-control-custom" asp-items="ViewBag.DepartmentsList">
                        </select>
                        <span asp-validation-for="DepartmentId" class="field-error"></span>
                    </div>
                    <div>
                        <label asp-for="Name" class="form-label form-label-custom">Designation Title</label>
                        <input asp-for="Name" class="form-control form-control-custom" />
                        <span asp-validation-for="Name" class="field-error"></span>
                    </div>
                </div>

                <div class="form-field-group mb-5">
                    <div class="form-section-label">
                        <i class="fa-solid fa-money-bill-wave"></i> Compensation
                    </div>
                    <div class="mb-3">
                        <label asp-for="SalaryGrade" class="form-label form-label-custom">Salary Grade</label>
                        <input asp-for="SalaryGrade" class="form-control form-control-custom" />
                        <span asp-validation-for="SalaryGrade" class="field-error"></span>
                    </div>
                    <div>
                        <label asp-for="BasicSalary" class="form-label form-label-custom">Basic Salary</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="BasicSalary" class="form-control form-control-custom" type="number" step="0.01" />
                        </div>
                        <span asp-validation-for="BasicSalary" class="field-error"></span>
                    </div>
                </div>

                <div class="form-actions">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary px-5">
                        <i class="fa-solid fa-floppy-disk me-2"></i>Update Designation
                    </button>
                </div>
            </form>
        </div>

    </div>
</div>
