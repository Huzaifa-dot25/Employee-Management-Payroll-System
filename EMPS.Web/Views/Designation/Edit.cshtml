@model EMPS.Web.Models.DesignationViewModel
@{
    ViewData["Title"] = "Edit Designation";
}

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card-flat">
            <div class="card-flat-header">
                <h5 class="m-0 fw-bold"><i class="fa-solid fa-pen text-primary me-2"></i>Edit Designation</h5>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="fa-solid fa-arrow-left me-1"></i>Back</a>
            </div>
            <div class="card-flat-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="DepartmentId" class="form-label form-label-custom">Department</label>
                        <select asp-for="DepartmentId" class="form-select form-control-custom" asp-items="ViewBag.DepartmentsList">
                        </select>
                        <span asp-validation-for="DepartmentId" class="text-danger" style="font-size: 0.8rem;"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label form-label-custom">Designation Name</label>
                        <input asp-for="Name" class="form-control form-control-custom" />
                        <span asp-validation-for="Name" class="text-danger" style="font-size: 0.8rem;"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SalaryGrade" class="form-label form-label-custom">Salary Grade</label>
                        <input asp-for="SalaryGrade" class="form-control form-control-custom" />
                        <span asp-validation-for="SalaryGrade" class="text-danger" style="font-size: 0.8rem;"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="BasicSalary" class="form-label form-label-custom">Basic Salary</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white text-muted" style="border-radius: 8px 0 0 8px; border-color: var(--border-color); font-weight: 500;">$</span>
                            <input asp-for="BasicSalary" class="form-control form-control-custom" style="border-radius: 0 8px 8px 0;" type="number" step="0.01" />
                        </div>
                        <span asp-validation-for="BasicSalary" class="text-danger" style="font-size: 0.8rem;"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                        <i class="fa-solid fa-floppy-disk me-2"></i>Update Designation
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
