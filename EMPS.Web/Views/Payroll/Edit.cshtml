@model EMPS.Web.Models.PayrollViewModel
@{
    ViewData["Title"] = "Edit Payroll";
}

<div class="form-page-header mb-4">
    <div class="form-page-icon"><i class="fa-solid fa-file-invoice-dollar"></i></div>
    <div>
        <h4 class="form-page-title">Edit Payroll Record</h4>
        <p class="form-page-sub">Update the payroll details for this period.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm ms-auto">
        <i class="fa-solid fa-arrow-left me-1"></i>Back
    </a>
</div>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-4"></div>

    <div class="row g-4 mb-4">
        <!-- Employee & Period -->
        <div class="col-12 col-lg-5">
            <div class="form-card h-100">
                <div class="form-card-section-title">
                    <i class="fa-solid fa-user-tie"></i> Employee & Period
                </div>
                <div class="mb-3">
                    <label asp-for="EmployeeId" class="form-label form-label-custom">Employee</label>
                    <select asp-for="EmployeeId" class="form-select form-control-custom" asp-items="ViewBag.Employees">
                        <option value="">— Select Employee —</option>
                    </select>
                    <span asp-validation-for="EmployeeId" class="field-error"></span>
                </div>
                <div class="row g-3">
                    <div class="col-7">
                        <label asp-for="Month" class="form-label form-label-custom">Month</label>
                        <select asp-for="Month" class="form-select form-control-custom">
                            @for (int i = 1; i <= 12; i++)
                            {
                                <option value="@i">@(new DateTime(2000, i, 1).ToString("MMMM"))</option>
                            }
                        </select>
                        <span asp-validation-for="Month" class="field-error"></span>
                    </div>
                    <div class="col-5">
                        <label asp-for="Year" class="form-label form-label-custom">Year</label>
                        <input asp-for="Year" class="form-control form-control-custom" type="number" />
                        <span asp-validation-for="Year" class="field-error"></span>
                    </div>
                </div>
                <div class="mt-3">
                    <label asp-for="Status" class="form-label form-label-custom">Payroll Status</label>
                    <select asp-for="Status" class="form-select form-control-custom">
                        <option value="Draft">📝 Draft</option>
                        <option value="Approved">✅ Approved</option>
                        <option value="Paid">💰 Paid</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Earnings -->
        <div class="col-12 col-lg-7">
            <div class="form-card mb-4">
                <div class="form-card-section-title text-success">
                    <i class="fa-solid fa-arrow-trend-up"></i> Earnings
                </div>
                <div class="row g-3">
                    <div class="col-12 col-sm-6">
                        <label asp-for="BasicSalary" class="form-label form-label-custom">Basic Salary</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="BasicSalary" class="form-control form-control-custom" type="number" step="0.01" />
                        </div>
                        <span asp-validation-for="BasicSalary" class="field-error"></span>
                    </div>
                    <div class="col-12 col-sm-6">
                        <label asp-for="Allowances" class="form-label form-label-custom">Allowances</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="Allowances" class="form-control form-control-custom" type="number" step="0.01" />
                        </div>
                    </div>
                    <div class="col-12 col-sm-6">
                        <label asp-for="Bonuses" class="form-label form-label-custom">Bonuses</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="Bonuses" class="form-control form-control-custom" type="number" step="0.01" />
                        </div>
                    </div>
                    <div class="col-12 col-sm-6">
                        <label asp-for="OvertimePay" class="form-label form-label-custom">Overtime Pay</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="OvertimePay" class="form-control form-control-custom" type="number" step="0.01" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Deductions -->
            <div class="form-card">
                <div class="form-card-section-title text-danger">
                    <i class="fa-solid fa-arrow-trend-down"></i> Deductions
                </div>
                <div class="row g-3">
                    <div class="col-12 col-sm-6">
                        <label asp-for="TaxDeductions" class="form-label form-label-custom">Tax Deductions</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="TaxDeductions" class="form-control form-control-custom" type="number" step="0.01" />
                        </div>
                    </div>
                    <div class="col-12 col-sm-6">
                        <label asp-for="OtherDeductions" class="form-label form-label-custom">Other Deductions</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="OtherDeductions" class="form-control form-control-custom" type="number" step="0.01" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="form-actions-bar">
        <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
        <button type="submit" class="btn btn-primary px-5">
            <i class="fa-solid fa-floppy-disk me-2"></i>Update Payroll
        </button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
